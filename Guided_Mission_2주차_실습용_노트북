      "source": [
        "# 여기에 새로 코드를 작성해서 논문 그림과 비슷하게 만들어 봅시다."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from collections import defaultdict\n",
        "\n",
        "# 작업 폴더 확인\n",
        "%cd /content/drive/MyDrive/binfo1-work/\n",
        "\n",
        "# 파일명\n",
        "infile = \"fivepcounts-filtered-RPF-siLuc.txt\"\n",
        "\n",
        "# 상대위치별 read count 저장\n",
        "pos_count = defaultdict(int)\n",
        "\n",
        "# 컬럼 구조:\n",
        "# 0 chrom\n",
        "# 1 fivep_start\n",
        "# 2 fivep_end\n",
        "# 3 count\n",
        "# 4 exon_chrom\n",
        "# 5 exon_start\n",
        "# 6 exon_end\n",
        "# 7 transcript_id\n",
        "# 8 start_codon_pos\n",
        "# 9 strand\n",
        "\n",
        "chunksize = 500000\n",
        "\n",
        "for chunk in pd.read_csv(\n",
        "    infile,\n",
        "    sep=\"\\t\",\n",
        "    header=None,\n",
        "    chunksize=chunksize\n",
        "):\n",
        "    # start codon 기준 상대 위치\n",
        "    # + strand만 사용했기 때문에 fivep_start - start_codon_pos\n",
        "    chunk[\"relpos\"] = chunk[1] - chunk[8]\n",
        "\n",
        "    # Fig S5A처럼 -50 ~ +50 주변만 사용\n",
        "    chunk = chunk[(chunk[\"relpos\"] >= -50) & (chunk[\"relpos\"] <= 50)]\n",
        "\n",
        "    # 상대위치별 count 합산\n",
        "    grouped = chunk.groupby(\"relpos\")[3].sum()\n",
        "\n",
        "    for pos, cnt in grouped.items():\n",
        "        pos_count[pos] += cnt\n",
        "\n",
        "# Series로 변환\n",
        "seLucCov = pd.Series(pos_count).sort_index()\n",
        "\n",
        "# 빠진 위치는 0으로 채우기\n",
        "seLucCov = seLucCov.reindex(range(-50, 51), fill_value=0)\n",
        "\n",
        "seLucCov.head(), seLucCov.tail()"
      ],
